{
  "manifest_version": 3,
  "name": "Toki – AI Usage Monitor",
  "version": "0.2.0",
  "description": "Real-time token usage tracker and smart prompt optimizer for ChatGPT, Gemini, Claude, and Grok.",
  "author": "Hari",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Toki – AI Usage Monitor",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://grok.x.ai/*",
        "https://x.com/i/grok*"
      ],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://grok.x.ai/*",
    "https://x.com/i/grok*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://grok.x.ai/*",
        "https://x.com/*"
      ]
    }
  ]
}
